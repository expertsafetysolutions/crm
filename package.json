{
  "name": "expert-safety-crm-pwa",
  "version": "1.0.0",
  "description": "Expert Safety Solutions Full-Stack Field Service & CRM PWA",
  "scripts": {
    "start:server": "npm --prefix server start",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "build:client": "npm --prefix client run build",
    "test:workflow": "npm --prefix server run test:workflow"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.4",
    "googleapis": "^173.0.0"
  }
}
